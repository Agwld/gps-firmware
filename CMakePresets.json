{
    "version": 3,
    "configurePresets": [
        {
            "name": "default",
            "hidden": true,
            "generator": "Ninja",
            "binaryDir": "${sourceDir}/build/${presetName}",
            "toolchainFile": "${sourceDir}/cmake/gcc-arm-none-eabi.cmake",
            "cacheVariables": {
            }
        },
        {
            "name": "Debug",
            "inherits": "default",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug"
            }
        },
        {
            "name": "Release",
            "inherits": "default",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release"
            }
        },
        {
            "name": "Test",
            "generator": "Ninja",
            "binaryDir": "${sourceDir}/build/Test",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug",
                "GPS_HOST_TESTS": "ON"
            }
        }
    ],
    "buildPresets": [
        {
            "name": "Debug",
            "configurePreset": "Debug"
        },
        {
            "name": "Release",
            "configurePreset": "Release"
        },
        {
            "name": "Test",
            "configurePreset": "Test"
        }
    ],
    "testPresets": [
        {
            "name": "Test",
            "configurePreset": "Test",
            "output": {
                "outputOnFailure": true
            }
        }
    ]
}
